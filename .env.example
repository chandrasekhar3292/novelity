# Copy this file to .env and fill in your values

# Required: OpenAI API key for idea domain/concept extraction
OPENAI_API_KEY=sk-...

# Embedding model (sentence-transformers compatible)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Data directory (papers.json and index.faiss will be stored here)
DATA_DIR=data

# Number of similar papers to retrieve per query
TOP_K=20

# FastAPI debug mode
DEBUG=true
